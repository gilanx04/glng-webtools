---
const { title = "GLNG Tools" } = Astro.props;
---
<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style is:global>
      body { font-family: 'Inter', sans-serif; }
      .mesh-bg {
        background-image:
          radial-gradient(at 20% 50%, rgba(59,130,246,0.3) 0px, transparent 50%),
          radial-gradient(at 80% 20%, rgba(99,102,241,0.2) 0px, transparent 50%),
          radial-gradient(at 40% 80%, rgba(139,92,246,0.2) 0px, transparent 50%);
      }
      .glass {
        background: rgba(255,255,255,0.85);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
      }
      .gradient-btn {
        background: linear-gradient(135deg, #1877F2, #0d5cb6);
      }
      .gradient-btn:hover {
        background: linear-gradient(135deg, #0d5cb6, #1877F2);
        transform: scale(1.02);
      }
      .success-btn {
        background: linear-gradient(135deg, #22c55e, #16a34a);
      }
      .success-btn:hover {
        background: linear-gradient(135deg, #16a34a, #22c55e);
        transform: scale(1.02);
      }
      .animate-spin {
        animation: spin 1s linear infinite;
      }
      @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }
    </style>
  </head>
  <body class="mesh-bg min-h-screen">
    <slot />
  </body>
</html>
