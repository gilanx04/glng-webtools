---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="IMAGE CALENDAR">
<div class="glass rounded-3xl shadow-2xl p-8 max-w-2xl w-full border border-white/50">
        <div class="text-center mb-8">
            <a href="/" class="inline-flex items-center gap-2 text-teal-600 hover:text-teal-800 transition-colors font-medium mb-6">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                Kembali
            </a>
            <div class="w-20 h-20 bg-gradient-to-br from-teal-500 to-cyan-600 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg">
                <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
            <h1 class="text-4xl font-extrabold mb-2">
                <span class="bg-gradient-to-r from-teal-600 to-cyan-600 bg-clip-text text-transparent">Calendar Image</span>
            </h1>
            <p class="text-gray-600">Generate gambar kalender bulan tertentu</p>
        </div>

        <div class="space-y-4 mb-6">
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">Bulan</label>
                    <select id="month" class="w-full px-4 py-3 bg-white/70 border-2 border-gray-200 rounded-xl focus:border-teal-500 focus:outline-none focus:ring-4 focus:ring-teal-500/20 transition-all text-gray-800">
                        <option value="1">Januari</option>
                        <option value="2">Februari</option>
                        <option value="3" selected>Maret</option>
                        <option value="4">April</option>
                        <option value="5">Mei</option>
                        <option value="6">Juni</option>
                        <option value="7">Juli</option>
                        <option value="8">Agustus</option>
                        <option value="9">September</option>
                        <option value="10">Oktober</option>
                        <option value="11">November</option>
                        <option value="12">Desember</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">Tahun</label>
                    <input type="number" id="year" value="2026" min="1900" max="2100"
                        class="w-full px-4 py-3 bg-white/70 border-2 border-gray-200 rounded-xl focus:border-teal-500 focus:outline-none focus:ring-4 focus:ring-teal-500/20 transition-all text-gray-800">
                </div>
            </div>
            <button onclick="generateCalendar()"
                class="w-full gradient-btn text-white font-bold py-4 px-6 rounded-xl transition-all duration-300 active:scale-[0.98] shadow-lg shadow-teal-500/30">
                Generate Calendar
            </button>
        </div>

        <div id="result" class="space-y-4"></div>
    </div>

    <script>
        async function generateCalendar() {
            const month = document.getElementById('month').value;
            const year = document.getElementById('year').value;
            const resultDiv = document.getElementById('result');
            const button = document.querySelector('button');

            if (!month || !year) {
                resultDiv.innerHTML = `<div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-xl"><p class="text-red-700 font-medium">Pilih bulan dan tahun</p></div>`;
                return;
            }

            resultDiv.innerHTML = `<div class="text-center py-6"><div class="inline-block animate-spin rounded-full h-10 w-10 border-b-3 border-teal-600"></div><p class="text-gray-600 mt-3 font-medium">Generating...</p></div>`;
            button.disabled = true;
            button.textContent = 'Generating...';

            try {
                const apiUrl = `https://api.ryzumi.net/api/image/calendar?month=${month}&year=${year}`;

                const response = await fetch(apiUrl, {
                    method: 'GET',
                    headers: { 'accept': 'image/png' }
                });

                if (response.ok) {
                    const blob = await response.blob();
                    const imageUrl = URL.createObjectURL(blob);

                    let html = `<div class="bg-gradient-to-br from-gray-50 to-teal-50 rounded-xl p-5 border border-teal-100">`;
                    html += `<h3 class="font-bold text-gray-800 mb-3">Calendar ${month}/${year}</h3>`;
                    html += `<img src="${imageUrl}" alt="Calendar ${month}/${year}" class="w-full rounded-lg shadow-md mb-3">`;
                    html += `<a href="${imageUrl}" download="calendar-${month}-${year}.png"
                                class="success-btn text-white font-bold py-4 px-6 rounded-xl transition-all duration-300 active:scale-[0.98] shadow-lg shadow-teal-500/30 text-center block">
                                ⬇️ Download Calendar (PNG)
                            </a>`;
                    html += `</div>`;

                    resultDiv.innerHTML = html;
                } else {
                    resultDiv.innerHTML = `<div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-xl"><p class="text-red-700 font-medium">Gagal generate calendar</p></div>`;
                }
            } catch (error) {
                resultDiv.innerHTML = `<div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-xl"><p class="text-red-700 font-medium">Terjadi kesalahan: ${error.message}</p></div>`;
            } finally {
                button.disabled = false;
                button.textContent = 'Generate Calendar';
            }
        }
    </script>
</BaseLayout>
