---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="WP MOE Search - Web Tools">
  <div class="glass rounded-3xl shadow-2xl p-8 max-w-6xl w-full border border-white/50">
        <div class="text-center mb-8">
            <a href="/" class="inline-flex items-center gap-2 text-purple-700 hover:text-purple-900 transition-colors font-medium mb-6">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                Kembali
            </a>
            <div class="w-20 h-20 bg-gradient-to-br from-purple-700 to-pink-600 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg">
                <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
            <h1 class="text-4xl font-extrabold mb-2">
                <span class="bg-gradient-to-r from-purple-700 to-pink-600 bg-clip-text text-transparent">WP MOE Search</span>
            </h1>
            <p class="text-gray-600">Pencarian live wallpaper anime</p>
        </div>

        <div class="space-y-4 mb-6">
            <div class="relative">
                <input type="text" id="query" placeholder="Masukkan judul anime/character..."
                    class="w-full px-5 py-4 bg-white/70 border-2 border-gray-200 rounded-xl focus:border-purple-600 focus:outline-none focus:ring-4 focus:ring-purple-600/20 transition-all text-gray-800 placeholder-gray-400"
                    autocomplete="off">
                <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none">
                    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                </div>
            </div>
            <button onclick="searchWallpaper()"
                class="w-full gradient-btn text-white font-bold py-4 px-6 rounded-xl transition-all duration-300 active:scale-[0.98] shadow-lg shadow-purple-500/30">
                Cari Wallpaper
            </button>
        </div>

        <div id="result" class="space-y-4"></div>
    </div>

    <script is:inline>
        async function searchWallpaper() {
            const query = document.getElementById('query').value.trim();
            const resultDiv = document.getElementById('result');
            const button = document.querySelector('button');

            if (!query) {
                resultDiv.innerHTML = `<div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-xl"><p class="text-red-700 font-medium">Masukkan kata kunci terlebih dahulu</p></div>`;
                return;
            }

            resultDiv.innerHTML = `<div class="text-center py-6"><div class="inline-block animate-spin rounded-full h-10 w-10 border-b-3 border-purple-800"></div><p class="text-gray-600 mt-3 font-medium">Mencari...</p></div>`;
            button.disabled = true;
            button.textContent = 'Mencari...';

            try {
                const encodedQuery = encodeURIComponent(query);
                const apiUrl = `https://api.ryzumi.net/api/search/wallpaper-moe?query=${encodedQuery}`;

                const response = await fetch(apiUrl, {
                    method: 'GET',
                    headers: { 'accept': 'application/json' }
                });
                const data = await response.json();

                if (data.success && data.result && Array.isArray(data.result)) {
                    if (data.result.length > 0) {
                        let html = `<div class="mb-4"><p class="text-gray-600 text-sm font-medium">Ditemukan ${data.result.length} wallpaper:</p></div>`;
                        html += `<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">`;

                        data.result.forEach((wp) => {
                            html += `
                                <div class="bg-gradient-to-br from-gray-50 to-purple-50 rounded-xl overflow-hidden border border-purple-100 hover:border-purple-400 hover:shadow-xl transition-all">
                                    <img src="${wp.wallpaper}" alt="${wp.title}" class="w-full h-40 object-cover">
                                    <div class="p-4">
                                        <h3 class="font-bold text-gray-800 text-sm mb-2 line-clamp-2">${wp.title}</h3>
                                        <a href="${wp.urlLiveWallpaper || wp.link}" target="_blank" rel="noopener"
                                            class="block w-full gradient-btn text-white font-bold py-2 px-4 rounded-lg text-center text-sm transition-all duration-300 active:scale-[0.98]">
                                            Download Wallpaper
                                        </a>
                                    </div>
                                </div>
                            `;
                        });

                        html += `</div>`;
                        resultDiv.innerHTML = html;
                    } else {
                        resultDiv.innerHTML = `<div class="bg-yellow-50 border-l-4 border-yellow-500 p-4 rounded-xl"><p class="text-yellow-700 font-medium">Tidak ada wallpaper yang ditemukan</p></div>`;
                    }
                } else {
                    resultDiv.innerHTML = `<div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-xl"><p class="text-red-700 font-medium">${data.message || 'Gagal mencari wallpaper'}</p></div>`;
                }
            } catch (error) {
                resultDiv.innerHTML = `<div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-xl"><p class="text-red-700 font-medium">Terjadi kesalahan: ${error.message}</p></div>`;
            } finally {
                button.disabled = false;
                button.textContent = 'Cari Wallpaper';
            }
        }

        document.getElementById('query').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') searchWallpaper();
        });
    </script>
</BaseLayout>
