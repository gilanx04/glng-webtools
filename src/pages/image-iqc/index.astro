---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="iPhone Quotly Chat - Web Tools">
  <div class="glass rounded-3xl shadow-2xl p-8 max-w-2xl w-full border border-white/50">
        <div class="text-center mb-8">
            <a href="/" class="inline-flex items-center gap-2 text-gray-600 hover:text-black transition-colors font-medium mb-6">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                Kembali
            </a>
            <div class="w-20 h-20 bg-gradient-to-br from-gray-700 to-gray-900 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg">
                <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
            </div>
            <h1 class="text-4xl font-extrabold mb-2">
                <span class="bg-gradient-to-r from-gray-700 to-gray-900 bg-clip-text text-transparent">iPhone Quotly Chat</span>
            </h1>
            <p class="text-gray-600">Generate screenshot iPhone chat</p>
        </div>

        <div class="space-y-4 mb-6">
            <textarea id="text" rows="4" placeholder="Masukkan teks (gunakan emoji jika perlu)..."
                class="w-full px-5 py-4 bg-white/70 border-2 border-gray-200 rounded-xl focus:border-gray-800 focus:outline-none focus:ring-4 focus:ring-gray-800/20 transition-all text-gray-800 placeholder-gray-400 resize-none"></textarea>
            <button id="actionBtn"
                class="w-full gradient-btn text-white font-bold py-4 px-6 rounded-xl transition-all duration-300 active:scale-[0.98] shadow-lg shadow-gray-500/30">
                Generate Image
            </button>
        </div>

        <div id="result" class="space-y-4"></div>
    </div>

    <script is:inline>
        async function generateImage() {
            const text = document.getElementById('text').value.trim();
            const resultDiv = document.getElementById('result');
            const button = document.querySelector('button');

            if (!text) {
                resultDiv.innerHTML = `<div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-xl"><p class="text-red-700 font-medium">Masukkan teks terlebih dahulu</p></div>`;
                return;
            }

            resultDiv.innerHTML = `<div class="text-center py-6"><div class="inline-block animate-spin rounded-full h-10 w-10 border-b-3 border-gray-800"></div><p class="text-gray-600 mt-3 font-medium">Generating...</p></div>`;
            button.disabled = true;
            button.textContent = 'Generating...';

            try {
                const encodedText = encodeURIComponent(text);
                const apiUrl = `/api/image/iqc?text=${encodedText}`;

                 const response = await fetch(apiUrl);

                 if (response.ok) {
                     const blob = await response.blob();
                    const imageUrl = URL.createObjectURL(blob);

                    let html = `<div class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-xl p-5 border border-gray-200">`;
                    html += `<h3 class="font-bold text-gray-800 mb-3">Generated Image</h3>`;
                    html += `<img src="${imageUrl}" alt="iPhone Chat" class="w-full rounded-lg shadow-md mb-3">`;
                    html += `<a href="${imageUrl}" download="iqc-${Date.now()}.png"
                                class="success-btn text-white font-bold py-4 px-6 rounded-xl transition-all duration-300 active:scale-[0.98] shadow-lg shadow-gray-500/30 text-center block">
                                ⬇️ Download Image (PNG)
                            </a>`;
                    html += `</div>`;

                    resultDiv.innerHTML = html;
                } else {
                    resultDiv.innerHTML = `<div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-xl"><p class="text-red-700 font-medium">Gagal generate image</p></div>`;
                }
            } catch (error) {
                resultDiv.innerHTML = `<div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-xl"><p class="text-red-700 font-medium">Terjadi kesalahan: ${error.message}</p></div>`;
            } finally {
                button.disabled = false;
                button.textContent = 'Generate Image';
            }
        }
    
        document.getElementById("actionBtn").addEventListener("click", generateImage);
      </script>
</BaseLayout>
