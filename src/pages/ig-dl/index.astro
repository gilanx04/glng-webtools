---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Instagram Downloader - Web Tools">
  <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
        body { font-family: 'Inter', sans-serif; }

        .mesh-bg {
            background-image:
                radial-gradient(at 20% 50%, rgba(228, 64, 95, 0.3) 0px, transparent 50%),
                radial-gradient(at 80% 20%, rgba(193, 53, 132, 0.2) 0px, transparent 50%),
                radial-gradient(at 40% 80%, rgba(252, 175, 69, 0.2) 0px, transparent 50%);
        }

        .glass {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
        }

        .gradient-btn {
            background: linear-gradient(135deg, #E4405F, #c13584);
        }

        .gradient-btn:hover {
            background: linear-gradient(135deg, #c13584, #E4405F);
            transform: scale(1.02);
        }

        .success-btn {
            background: linear-gradient(135deg, #E4405F, #c13584);
        }

        .success-btn:hover {
            background: linear-gradient(135deg, #c13584, #E4405F);
            transform: scale(1.02);
        }
    </style>
  <div class="glass rounded-3xl shadow-2xl p-8 max-w-2xl w-full border border-white/50">
        <div class="text-center mb-8">
            <a href="/" class="inline-flex items-center gap-2 text-pink-600 hover:text-pink-800 transition-colors font-medium mb-6">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                Kembali
            </a>
            <div class="w-20 h-20 bg-gradient-to-br from-pink-500 to-purple-600 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg">
                <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678a6.162 6.162 0 100 12.324 6.162 6.162 0 100-12.324zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405a1.441 1.441 0 100 2.882 1.441 1.441 0 100-2.882z"/></svg>
            </div>
            <h1 class="text-4xl font-extrabold mb-2">
                <span class="bg-gradient-to-r from-pink-600 to-purple-600 bg-clip-text text-transparent">Instagram Downloader</span>
            </h1>
            <p class="text-gray-600">Download foto & video Instagram</p>
        </div>

        <div class="space-y-4 mb-6">
            <div class="relative">
                <input type="url" id="igUrl" placeholder="Masukkan URL Instagram (post/reel)..."
                    class="w-full px-5 py-4 bg-white/70 border-2 border-gray-200 rounded-xl focus:border-pink-500 focus:outline-none focus:ring-4 focus:ring-pink-500/20 transition-all text-gray-800 placeholder-gray-400"
                    autocomplete="off">
                <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none">
                    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101"/></svg>
                </div>
            </div>
            <button onclick="downloadMedia()"
                class="w-full gradient-btn text-white font-bold py-4 px-6 rounded-xl transition-all duration-300 active:scale-[0.98] shadow-lg shadow-pink-500/30">
                Download
            </button>
        </div>

        <div id="result" class="space-y-4"></div>
    </div>

    <script>
        async function downloadMedia() {
            const url = document.getElementById('igUrl').value.trim();
            const resultDiv = document.getElementById('result');
            const button = document.querySelector('button');

            if (!url) {
                resultDiv.innerHTML = `<div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-xl"><p class="text-red-700 font-medium">Masukkan URL Instagram terlebih dahulu</p></div>`;
                return;
            }

            resultDiv.innerHTML = `<div class="text-center py-6"><div class="inline-block animate-spin rounded-full h-10 w-10 border-b-3 border-pink-600"></div><p class="text-gray-600 mt-3 font-medium">Memproses...</p></div>`;
            button.disabled = true;
            button.textContent = 'Memproses...';

            try {
                const encodedUrl = encodeURIComponent(url);
                const apiUrl = `https://api.ryzumi.net/api/downloader/instagram?url=${encodedUrl}`;

                const response = await fetch(apiUrl, {
                    method: 'GET',
                    headers: { 'accept': 'application/json' }
                });
                const data = await response.json();

                if (data.success && data.result) {
                    const { title, views, likes, author, media } = data.result;
                    let html = '';

                    if (author || title) {
                        html += `<div class="bg-gradient-to-br from-gray-50 to-pink-50 rounded-xl p-5 mb-4 border border-pink-100">`;
                        if (author && author.profilePicture) {
                            html += `<div class="flex items-center gap-3 mb-3">
                                <img src="${author.profilePicture}" class="w-10 h-10 rounded-full border-2 border-pink-200">
                                <div>
                                    <p class="font-bold text-gray-800">@${author.username || 'unknown'}</p>
                                    <p class="text-xs text-gray-500">${Number(author.followers || 0).toLocaleString()} followers</p>
                                </div>
                            </div>`;
                        }
                        if (title) html += `<p class="text-gray-700 text-sm mb-2">${title}</p>`;
                        if (views || likes) {
                            html += `<div class="flex gap-4 text-xs text-gray-500">
                                ${views ? `<span>👁️ ${Number(views).toLocaleString()} views</span>` : ''}
                                ${likes ? `<span>❤️ ${Number(likes).toLocaleString()} likes</span>` : ''}
                            </div>`;
                        }
                        html += `</div>`;
                    }

                    if (media && media.all && media.all.length > 0) {
                        media.all.forEach((item) => {
                            const icon = item.type === 'image' ? '📷' : item.type === 'audio' ? '🎵' : '🎬';
                            const label = item.type === 'video' ? 'Video' : item.type === 'audio' ? 'Audio' : 'Image';
                            html += `
                                <a href="${item.url}" target="_blank" rel="noopener"
                                    class="success-btn text-white font-bold py-4 px-6 rounded-xl transition-all duration-300 active:scale-[0.98] shadow-lg shadow-pink-500/30 text-center block">
                                    ${icon} Download ${label} (${item.extension || 'file'})
                                </a>
                            `;
                        });
                    } else {
                        html += `<div class="bg-yellow-50 border-l-4 border-yellow-500 p-4 rounded-xl"><p class="text-yellow-700 font-medium">Tidak ada media yang ditemukan</p></div>`;
                    }
                    resultDiv.innerHTML = html;
                } else {
                    let errorMsg = data.errors || data.message || 'Gagal memproses URL';
                    if (errorMsg.includes('Struct item')) {
                        errorMsg = 'Konten tidak ditemukan. Pastikan URL valid dan konten bersifat publik.';
                    }
                    resultDiv.innerHTML = `<div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-xl"><p class="text-red-700 font-medium">${errorMsg}</p></div>`;
                }
            } catch (error) {
                resultDiv.innerHTML = `<div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-xl"><p class="text-red-700 font-medium">Terjadi kesalahan: ${error.message}</p></div>`;
            } finally {
                button.disabled = false;
                button.textContent = 'Download';
            }
        }

        document.getElementById('igUrl').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') downloadMedia();
        });
    </script>
</BaseLayout>
