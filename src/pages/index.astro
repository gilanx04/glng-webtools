---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="GLNG - Web Tools">
  <div class="min-h-screen flex items-center justify-center p-4">
    <div class="glass rounded-3xl shadow-2xl p-8 max-w-4xl w-full border border-white/50">
      <h1 class="text-3xl font-bold text-center mb-8 text-gray-800">GLNG Web Tools</h1>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <a href="/fb-dl/" class="glass rounded-xl p-4 hover:scale-105 transition-transform text-center">
          <h2 class="text-lg font-semibold text-blue-600">Facebook Downloader</h2>
        </a>
        <a href="/gd-dl/" class="glass rounded-xl p-4 hover:scale-105 transition-transform text-center">
          <h2 class="text-lg font-semibold text-green-600">Google Drive Downloader</h2>
        </a>
        <a href="/ig-dl/" class="glass rounded-xl p-4 hover:scale-105 transition-transform text-center">
          <h2 class="text-lg font-semibold text-pink-600">Instagram Downloader</h2>
        </a>
        <a href="/tt-dl/" class="glass rounded-xl p-4 hover:scale-105 transition-transform text-center">
          <h2 class="text-lg font-semibold text-gray-800">TikTok Downloader</h2>
        </a>
        <a href="/search-pddikti/" class="glass rounded-xl p-4 hover:scale-105 transition-transform text-center">
          <h2 class="text-lg font-semibold text-indigo-600">Cari PDDIKTI</h2>
        </a>
        <a href="/search-wpmoe/" class="glass rounded-xl p-4 hover:scale-105 transition-transform text-center">
          <h2 class="text-lg font-semibold text-purple-600">Cari WPMoE</h2>
        </a>
        <a href="/image-calendar/" class="glass rounded-xl p-4 hover:scale-105 transition-transform text-center">
          <h2 class="text-lg font-semibold text-yellow-600">Image Calendar</h2>
        </a>
        <a href="/image-iqc/" class="glass rounded-xl p-4 hover:scale-105 transition-transform text-center">
          <h2 class="text-lg font-semibold text-red-600">Image IQC</h2>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
