---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="GLNG - Web Tools">
  <div class="min-h-screen flex items-center justify-center p-4">
    <div class="glass rounded-3xl shadow-2xl p-8 max-w-2xl w-full border border-white/50">
      <div class="text-center mb-8">
        <h1 class="text-4xl font-extrabold mb-2">
          <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">GLNG Web Tools</span>
        </h1>
        <p class="text-gray-600">Kumpulan tools praktis untuk kebutuhan harian</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <a href="/fb-dl/" class="flex items-center gap-3 p-4 rounded-xl bg-white/50 hover:bg-blue-50 transition-colors border border-gray-100 hover:border-blue-200">
          <span class="text-blue-600 font-semibold">FB</span>
          <span class="text-gray-800 font-medium">Facebook Downloader</span>
        </a>
        <a href="/gd-dl/" class="flex items-center gap-3 p-4 rounded-xl bg-white/50 hover:bg-green-50 transition-colors border border-gray-100 hover:border-green-200">
          <span class="text-green-600 font-semibold">GD</span>
          <span class="text-gray-800 font-medium">Google Drive DL</span>
        </a>
        <a href="/ig-dl/" class="flex items-center gap-3 p-4 rounded-xl bg-white/50 hover:bg-pink-50 transition-colors border border-gray-100 hover:border-pink-200">
          <span class="text-pink-600 font-semibold">IG</span>
          <span class="text-gray-800 font-medium">Instagram Downloader</span>
        </a>
        <a href="/tt-dl/" class="flex items-center gap-3 p-4 rounded-xl bg-white/50 hover:bg-gray-50 transition-colors border border-gray-100 hover:border-gray-200">
          <span class="text-gray-800 font-semibold">TT</span>
          <span class="text-gray-800 font-medium">TikTok Downloader</span>
        </a>
        <a href="/search-pddikti/" class="flex items-center gap-3 p-4 rounded-xl bg-white/50 hover:bg-indigo-50 transition-colors border border-gray-100 hover:border-indigo-200">
          <span class="text-indigo-600 font-semibold">PD</span>
          <span class="text-gray-800 font-medium">Cari PDDIKTI</span>
        </a>
        <a href="/search-wpmoe/" class="flex items-center gap-3 p-4 rounded-xl bg-white/50 hover:bg-purple-50 transition-colors border border-gray-100 hover:border-purple-200">
          <span class="text-purple-600 font-semibold">WP</span>
          <span class="text-gray-800 font-medium">Cari WPMoE</span>
        </a>
        <a href="/image-calendar/" class="flex items-center gap-3 p-4 rounded-xl bg-white/50 hover:bg-yellow-50 transition-colors border border-gray-100 hover:border-yellow-200">
          <span class="text-yellow-600 font-semibold">IC</span>
          <span class="text-gray-800 font-medium">Image Calendar</span>
        </a>
        <a href="/image-iqc/" class="flex items-center gap-3 p-4 rounded-xl bg-white/50 hover:bg-red-50 transition-colors border border-gray-100 hover:border-red-200">
          <span class="text-red-600 font-semibold">IQ</span>
          <span class="text-gray-800 font-medium">Image IQC</span>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
